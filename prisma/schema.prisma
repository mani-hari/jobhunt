generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Keyword {
  id              String   @id @default(cuid())
  original        String
  canonicalTitles String
  createdAt       DateTime @default(now())
}

model Job {
  id              String    @id @default(cuid())
  title           String
  company         String
  location        String
  description     String
  jobType         String?
  employment      String?
  level           String?
  industry        String?
  salaryMin       Float?
  salaryMax       Float?
  sourceUrl       String
  source          String
  postedAt        DateTime?
  fetchedAt       DateTime  @default(now())
  dedupeHash      String    @unique
  score           Int?
  scoreSummary    String?
  scoreDetails    String?
  status          String    @default("discovered")
  shortlistedAt   DateTime?
  appliedAt       DateTime?
  generatedResume String?
  generatedCover  String?
  generatedEmail  String?
  fitAnalysis     String?

  @@index([status])
  @@index([fetchedAt])
}

model Resume {
  id         String   @id @default(cuid())
  fileName   String
  rawText    String
  uploadedAt DateTime @default(now())
}

model CompanyBoard {
  id        String   @id @default(cuid())
  ats       String   // "greenhouse" | "lever" | "ashby"
  slug      String   // board slug, e.g. "stripe"
  name      String   // human-readable label
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([ats, slug])
}

model Settings {
  id                  String  @id @default("singleton")
  preferredLocation   String  @default("Toronto, Canada")
  openToRemote        Boolean @default(true)
  openToRelocation    String  @default("Within Canada")
  minSalary           Float?
  preferredIndustries String  @default("[\"Banking\",\"Financial Services\",\"Insurance\",\"Fintech\",\"Tech\"]")
  dealBreakers        String?
  yearsExperience     Int     @default(7)
  keyStrengths        String  @default("[\"Data Governance\",\"Business Analysis\",\"Requirements Gathering\",\"Stakeholder Management\",\"Power BI\",\"SQL\"]")
  careerGapNote       String  @default("Returning after ~1.4 year career break for personal/family reasons — fully re-engaged and ready")
}
