# Neon Postgres (https://neon.tech) — pooled URL
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.us-east-1.aws.neon.tech/jobhunt?sslmode=require"

# Anthropic Claude (https://console.anthropic.com)
ANTHROPIC_API_KEY=
# Model overrides — defaults are sensible. Haiku for cheap/fast (scoring, keyword expansion),
# Opus for high-quality long-form (resume / cover letter / outreach email generation).
ANTHROPIC_SCORING_MODEL=claude-haiku-4-5
ANTHROPIC_GENERATION_MODEL=claude-opus-4-7

# Adzuna (https://developer.adzuna.com/)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# JSearch via RapidAPI (optional)
RAPIDAPI_KEY=

# Google Programmable Search (optional, free 100/day)
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=
